{
  "buildCommand": "node www/scripts/copy-install.mjs",
  "outputDirectory": "www/public",
  "installCommand": "echo skip",
  "headers": [
    {
      "source": "/install",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/install.sh",
      "destination": "/install"
    }
  ]
}
