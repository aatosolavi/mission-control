{
  "manifest_version": 3,
  "name": "Mission Control",
  "version": "0.2.0",
  "description": "Real terminal as a browser tab for Helium (xterm.js + local PTY). Minimal MVP of the Mission Control vision.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Start Mission from this page"
  }
}
