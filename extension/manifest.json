{
  "manifest_version": 3,
  "name": "T-0",
  "version": "0.2.0",
  "description": "T-0 — real terminal as a browser tab (xterm.js + local PTY). Pick a workspace, launch an agent.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open T-0"
  }
}
